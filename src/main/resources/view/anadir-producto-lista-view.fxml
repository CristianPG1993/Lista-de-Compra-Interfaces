<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER"
      maxHeight="-Infinity"
      maxWidth="-Infinity"
      minHeight="-Infinity"
      minWidth="-Infinity"
      prefHeight="420.0"
      prefWidth="520.0"
      spacing="10.0"
      styleClass="container-form"
      stylesheets="@../css/styles.css"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.listacompra.interfaces.listacompra.controller.AnadirProductosListaController">

   <padding>
      <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
   </padding>

   <children>
      <Label alignment="CENTER"
             styleClass="titulo-modulo"
             stylesheets="@../css/styles.css"
             text="Añadir Producto a Lista" />

      <ComboBox fx:id="cmbListas"
                prefWidth="300.0"
                promptText="Selecciona una lista" />

      <ComboBox fx:id="cmbProductos"
                prefWidth="300.0"
                promptText="Selecciona un producto" />

      <TextField fx:id="txtCantidad"
                 alignment="CENTER"
                 promptText="Cantidad"
                 styleClass="input-form"
                 stylesheets="@../css/styles.css" />

      <HBox alignment="CENTER" spacing="10.0">
         <children>
            <Button mnemonicParsing="false"
                    onAction="#onAnadirProductoLista"
                    styleClass="btn-registrar"
                    stylesheets="@../css/styles.css"
                    text="Añadir a lista" />

            <Button mnemonicParsing="false"
                    onAction="#onLimpiarFormulario"
                    styleClass="btn-volver"
                    stylesheets="@../css/styles.css"
                    text="Limpiar" />
         </children>
      </HBox>

      <Label fx:id="lblMensaje" />
   </children>
</VBox>