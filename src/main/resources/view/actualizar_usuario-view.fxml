<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefWidth="360.0" spacing="6.0" styleClass="container-form" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.listacompra.interfaces.listacompra.controller.ActualizarUsuarioController">
   <children>
      <Label styleClass="titulo-modulo" stylesheets="@../css/styles.css" text="Actualizar Usuario" />
       <HBox alignment="CENTER" prefWidth="260.0" spacing="10.0">
         <children>
            <TextField fx:id="txtDniBuscar" alignment="TOP_LEFT" promptText="DNI" styleClass="input-form" stylesheets="@../css/styles.css" />
            <Button fx:id="btnBuscar" mnemonicParsing="false" onAction="#onBuscarUsuario" styleClass="btn-buscar" stylesheets="@../css/styles.css" text="Buscar">
               <HBox.margin>
                  <Insets left="15.0" />
               </HBox.margin>
            </Button>
         </children>
      </HBox>
      <TextField fx:id="txtNombre" promptText="Nombre" styleClass="input-form" stylesheets="@../css/styles.css" />
      <TextField fx:id="txtApellido" promptText="Apellido" styleClass="input-form" stylesheets="@../css/styles.css" />
      <TextField fx:id="txtEmail" alignment="TOP_LEFT" promptText="Email" styleClass="input-form" stylesheets="@../css/styles.css" />
      <PasswordField fx:id="txtPassword" promptText="Contraseña" styleClass="input-form" stylesheets="@../css/styles.css" />
       <HBox alignment="CENTER" spacing="10.0">
         <children>
            <Button fx:id="btnGuardar" mnemonicParsing="false" onAction="#onGuardarCambios" styleClass="btn-registrar" stylesheets="@../css/styles.css" text="Guardar cambios" />
            <Button fx:id="btnLimpiar" mnemonicParsing="false" onAction="#onLimpiarFormulario" styleClass="btn-volver" stylesheets="@../css/styles.css" text="Limpiar" />
         </children>
      </HBox>
      <Label fx:id="lblMensaje" />
   </children>
   <padding>
      <Insets bottom="5.0" left="30.0" right="15.0" top="5.0" />
   </padding>
</VBox>
