<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="10.0" styleClass="container-form" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.listacompra.interfaces.listacompra.controller.EliminarUsuarioController">
   <children>
      <Label styleClass="titulo-modulo" stylesheets="@../css/styles.css" text="Eliminar Usuario" />
      <HBox alignment="CENTER" spacing="10.0">
         <children>
            <TextField fx:id="txtDniBuscar" promptText="DNI" styleClass="input-form" stylesheets="@../css/styles.css" />
         </children>
      </HBox>
      <Label fx:id="lblNombre" alignment="TOP_CENTER" text="Nombre:" />
      <Label fx:id="lblApellido" text="Apellido:" />
      <Label fx:id="lblEmail" text="Email:" />
      <Label fx:id="lblDni" text="DNI:" />
      <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="10.0">
         <children>
            <Button fx:id="btnEliminar" mnemonicParsing="false" onAction="#onEliminarUsuario" styleClass="btn-eliminar-usuario" stylesheets="@../css/styles.css" text="Eliminar" />
         </children>
      </HBox>
      <Label fx:id="lblMensaje" />
   </children>
   <padding>
      <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
   </padding>
</VBox>
