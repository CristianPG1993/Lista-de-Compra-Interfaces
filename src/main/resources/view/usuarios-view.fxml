<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" spacing="10.0" fx:controller="com.listacompra.interfaces.listacompra.controller.UsuariosController" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <Label styleClass="titulo-modulo" stylesheets="@../css/styles.css" text="Gestión de Usuarios" />
      <Button mnemonicParsing="false" onAction="#onCrearUsuario" text="Crear Usuario" />
      <Button mnemonicParsing="false" onAction="#onActualizarUsuario" text="Actualizar Usuario" />
      <Button mnemonicParsing="false" onAction="#onEliminarUsuario" text="Eliminar Usuario" />
      <Button mnemonicParsing="false" onAction="#onVolver" text="Volver" />
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" />
   </padding>
</VBox>
